      <style>
        <style-rule element='mark'>
          <encoding attr='color' field='[none:significance_flag:nk]' type='palette'>
            <map to='#59a14f'>
              <bucket>&quot;Significant (95\% CI)&quot;</bucket>
            </map>
            <map to='#e15759'>
              <bucket>&quot;Not significant&quot;</bucket>
