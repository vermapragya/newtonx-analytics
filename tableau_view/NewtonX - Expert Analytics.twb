      <style>
        <style-rule element='mark'>
          <encoding attr='color' field='[none:channel:nk]' type='palette'>
            <map to='#4e79a7'>
              <bucket>&quot;linkedin_outreach&quot;</bucket>
            </map>
            <map to='#e15759'>
              <bucket>&quot;paid_social&quot;</bucket>
            </map>
            <map to='#f28e2b'>
              <bucket>&quot;paid_search&quot;</bucket>
