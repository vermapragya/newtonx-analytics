      <aliases enabled='yes' />
      <column caption='#, Signups' datatype='integer' name='[#, Experts (copy)_2580271545720847]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(IF [event_name] = &apos;signup&apos; THEN [expert_id] END)' />
      </column>
      <column caption='%, Verification Rejected' datatype='real' name='[%, Activated (copy)_2580271541256205]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='countd(if [event_name]=&apos;verification_rejected&apos; then [expert_id] end)&#10;/&#10;countd(if [event_name]=&apos;signup&apos; then [expert_id] end)' />
      </column>
      <column caption='%, Net Activation Rate (60D)' datatype='real' name='[%, Profile Completed (copy)_2580271541112844]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(IF [event_name] = &apos;verification_approved&apos; AND [Calculation_2580271546032144] AND [Weeks to Activate (copy)_2580271530635270] &lt;= 60 THEN [expert_id] END) &#10;/ [#, Experts (copy)_2580271545720847]' />
      </column>
      <column caption='%, Verified' datatype='real' name='[%, Profile Started (copy)_2580271540682761]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='countd(if [event_name]=&apos;verification_approved&apos; then [expert_id] end)&#10;/&#10;countd(if [event_name]=&apos;signup&apos; then [expert_id] end)' />
      </column>
      <column caption='%, Profile Complete Rate' datatype='real' name='[%, Verified (copy)_2580271540846602]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(IF [event_name] IN (&apos;profile_completed&apos;, &apos;verification_submitted&apos;, &apos;verification_approved&apos;) THEN [expert_id] END)&#10;/ [#, Experts (copy)_2580271545720847]' />
      </column>
      <column caption='%, Submitted Rate' datatype='real' name='[%, Verified (copy)_2580271541014539]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(IF [event_name] IN (&apos;verification_submitted&apos;, &apos;verification_approved&apos;) THEN [expert_id] END)&#10;/ [#, Experts (copy)_2580271545720847]' />
      </column>
      <column caption='#, Experts' datatype='integer' name='[Calculation_2580271502774272]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([expert_id])' />
      </column>
      <column caption='Cohort Date' datatype='date' name='[Calculation_2580271521693697]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='{ FIXED [expert_id] : MIN(IF [event_name] = &apos;signup&apos; THEN [event_timestamp] END) }' />
      </column>
      <column caption='First Approval Date' datatype='date' name='[Calculation_2580271522766850]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='{ FIXED [expert_id] : MIN(IF [event_name] = &apos;first_engagement_completed&apos; THEN [event_timestamp] END) }' />
      </column>
      <column caption='Activated Within 60D' datatype='boolean' name='[Calculation_2580271522844675]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='DATEDIFF(&apos;day&apos;, [Calculation_2580271521693697], [Calculation_2580271522766850]) &lt;= 60' />
      </column>
      <column caption='%, Activation Rate' datatype='real' name='[Calculation_2580271522910212]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(IF [event_name] = &apos;first_engagement_completed&apos; THEN [expert_id] END) &#10;/ &#10;COUNTD([expert_id])' />
      </column>
      <column caption='Weeks to Activate' datatype='integer' name='[Calculation_2580271523823621]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='DATEDIFF(&apos;week&apos;, [Calculation_2580271521693697], [Calculation_2580271522766850])' />
      </column>
      <column caption='%, Profile Start Rate' datatype='real' name='[Calculation_2580271540236296]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(IF [event_name] IN (&apos;profile_started&apos;, &apos;profile_completed&apos;, &apos;verification_submitted&apos;, &apos;verification_approved&apos;) THEN [expert_id] END) &#10;/ [#, Experts (copy)_2580271545720847]' />
      </column>
      <column caption='#, Median Activation Days' datatype='real' name='[Calculation_2580271542792206]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='PERCENTILE([Weeks to Activate (copy)_2580271530635270], 0.5)' />
      </column>
      <column caption='Exclude Rejected' datatype='boolean' name='[Calculation_2580271546032144]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='{ FIXED [expert_id] : MAX(IF [event_name] = &apos;verification_rejected&apos; THEN 1 ELSE 0 END) } = 0' />
      </column>
      <column caption='%, Signups to Profile Start' datatype='real' name='[Calculation_2580271547211793]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(IF [event_name] IN (&apos;profile_started&apos;, &apos;profile_completed&apos;, &apos;verification_submitted&apos;, &apos;verification_approved&apos;) THEN [expert_id] END) /&#10;[#, Experts (copy)_2580271545720847]' />
      </column>
      <column caption='Days to Activate' datatype='integer' name='[Weeks to Activate (copy)_2580271530635270]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='DATEDIFF(&apos;day&apos;, [Calculation_2580271521693697], [Calculation_2580271522766850])' />
      </column>
